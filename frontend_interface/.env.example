# -------------------------------------------------------------------------- #
# FinBuddy minimal interface — environment configuration                     #
# Copy to `.env` and edit. Everything has a sensible default, so an empty     #
# .env works for both local (localhost) and docker-compose runs.             #
# -------------------------------------------------------------------------- #

# ---- Job mode ------------------------------------------------------------- #
# false = synchronous chat, no message broker needed (default; used by quickstart).
# true  = background jobs with live RabbitMQ notifications (used by docker-compose).
USE_ASYNC_JOBS=false

# ---- Auth ----------------------------------------------------------------- #
# MUST be identical for the frontend and backend: the frontend mints the JWT and
# the backend verifies it. Change it for anything beyond local dev.
JWT_SECRET_KEY=dev-secret-change-me

# ---- Database ------------------------------------------------------------- #
# Local default (no vars set): SQLite file in backend/finbuddy_local.db
# docker-compose sets DB_HOST=postgres automatically.
# Cloud: set a full SQLAlchemy URL and it wins over everything else.
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
DB_PASSWORD=finbuddy_dev_password

# ---- RabbitMQ (AMQP) ------------------------------------------------------ #
# Local default: amqp://guest:guest@localhost/
# docker-compose default: amqp://guest:guest@rabbitmq/
# Cloud (CloudAMQP): set CLOUDAMQP_URL and it wins.
# CLOUDAMQP_URL=amqps://user:pass@host/vhost
# RABBITMQ_URL=amqp://guest:guest@localhost/

# ---- Redis ---------------------------------------------------------------- #
# Local default: redis://localhost:6379/0
# docker-compose default: redis://redis:6379/0
# Cloud: set REDIS_URL, or REDIS_HOST/REDIS_PORT/REDIS_PASSWORD.
# REDIS_URL=redis://:password@host:6379/0

# ---- Frontend ------------------------------------------------------------- #
# Where the frontend finds the backend. Auto-resolves to localhost / backend
# service in docker. Set explicitly to point at a remote backend.
# BACKEND_URL=http://localhost:8008

# ---- Mock agent tuning ---------------------------------------------------- #
# How the stub "agent" behaves (number of progress steps and delay per step).
MOCK_JOB_STEPS=3
MOCK_JOB_STEP_SECONDS=1.5
